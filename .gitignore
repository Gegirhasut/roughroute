# Build artifacts.
/target

# Local Cargo config is machine-specific (e.g. redirecting target-dir off a
# slow/networked checkout); never committed so a fresh clone builds with
# Cargo defaults.
.cargo/config.toml

# Source OSM extracts: build-time input only, never checked in except the
# small, reproducible test fixture.
*.osm.pbf
!testdata/cyprus.osm.pbf

# Built region graphs: reproducible from source, never checked in.
*.graph

# Batch-build output (roughroute batch --out-dir dist).
/dist/

# WASM build output.
/pkg/
*.wasm
*.wasm.d.ts

# Generated Kotlin/UniFFI bindings.
/bindings/

# Editor/OS cruft.
.DS_Store
*.swp

# Scratch/temp.
*.tmp
.tmp/
